# ── RAG 적재 서버 (.env) ──
# app/rag/config.py 및 sources/*가 읽는 환경변수. 비워두면 아래 기본값을 쓴다.
# 실제 사용 시 이 파일을 .env로 복사해서 값을 채운다.

# 문서 크롤링 원본 (Automation Anywhere 공식 문서)
AA_DOCS_BASE_URL=https://docs.automationanywhere.com

# 산출물/로그 경로 (서버 루트 기준 상대경로)
INGEST_DATA_DIR=data/ingest
RAG_LOG_DIR=app/rag/logs

# 청킹 (pipeline.py eda로 문서 길이 분포 확인 후 조정)
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# ── DB ──
# RAG store(pgvector) 접속은 RAG_DATABASE_URL 하나로 정한다(백엔드 RPA-132/RPA-260과 동일 계약).
# raw psycopg라 libpq URL(postgresql://) 형식, sslmode=require 포함, -pooler 호스트 사용. 커밋 금지!
# ⚠️ 필수 — 폴백 제거(RPA-262). 미설정이면 database_dsn()이 RagDatabaseConfigurationError로 기동을
#    거부한다(RAG 코퍼스가 앱 DB에 조용히 섞이는 걸 방지). 로컬 단독 개발은 scripts/run_local*.py가
#    아래 DATABASE_*로 로컬 DSN을 만들어 주입하므로, 이 값을 비워도 로컬 러너는 동작한다.
# RAG_DATABASE_URL=
# 아래 DATABASE_*는 이제 RAG 폴백 base가 아니라, 로컬 러너(run_local*.py)가 로컬 RAG DSN을 만들 때
# 참조하는 "로컬 앱 DB" 값이다.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=a360
DATABASE_USERNAME=a360_admin
DATABASE_PASSWORD=a360_local_password

# ── RAG 저장소 전용 공유 DB (A360-Assistant-Backend RPA-132와 동일 계약) ──
# RAG 코퍼스(pgvector rag_documents)를 앱 DB와 분리된 전용 공유 DB(Neon 등)에 둘 때 설정.
# 필수(폴백 제거, RPA-262) — 미설정이면 기동 거부. 로컬 러너는 위 DATABASE_*로 로컬 DSN을 주입한다.
# ⚠️ RAG store는 raw psycopg라 libpq URL(postgresql://) 형식. sslmode=require 포함, -pooler 호스트 사용.
#    (SQLAlchemy용 'postgresql+psycopg://'를 붙여도 자동으로 벗겨 동작하나 postgresql://가 정석)
# ⚠️ A360-Assistant-Backend와 팀 공유 시 EMBEDDING_PROVIDER/MODEL/DIM을 전원 동일하게 +
#    적재(ingest) 때 쓴 값과 일치시킬 것(불일치 시 차원 오류·엉뚱한 벡터공간으로 검색이 깨진다).
#    크레덴셜 커밋 금지!
# RAG_DATABASE_URL=

# ── OpenSearch ──
OPENSEARCH_HOST=http://127.0.0.1:9200
OPENSEARCH_INDEX=rag_documents
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# ── 임베딩 (voyage 기본, 또는 openai) ──
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3.5
EMBEDDING_DIM=1024
VOYAGE_API_KEY=
OPENAI_API_KEY=

# ── 문서 파싱 에이전트 (parse-docs-agent: JAR 없는 패키지 리프 → 액션 스키마) ──
# 챗 모델(구조화 출력 지원 필요). 미설정 시 OPENAI_MODEL → 기본 gpt-5.4-mini 순으로 폴백.
AGENT_PARSE_MODEL=
OPENAI_MODEL=
# 처리할 리프 총수 상한(비용/시간 통제). 0이면 무제한.
AGENT_PARSE_LIMIT=0
# LLM 사용량(llm_usage) 기록 대상 관측 DB. 미설정 시 기록을 건너뛴다 — 앱/RAG DB로 폴백하지 않음
# (RPA-262, 백엔드 RPA-260과 동일 계약). 로컬은 보통 빈 값(= 사용량 기록 없음).
OBSERVABILITY_DATABASE_URL=

# ── 소스 수집 (선택) ──
# Control Room 봇 목록/JSON 수집 (pipeline.py bots / export-packages)
CR_URL=
CR_USERNAME=
CR_API_KEY=
CR_PASSWORD=
# 공개 GitHub 하베스트 (pipeline.py harvest-github) — 없어도 동작하나 rate limit이 낮아짐
GITHUB_TOKEN=
