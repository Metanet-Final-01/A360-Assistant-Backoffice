# ── 모니터링 서버 백엔드 (.env) ──
# 위치: ops-server/backend/.env (observability/backend_client.py가 여기서 로드).
# 실제 사용 시 이 파일을 .env로 복사해서 값을 채운다.

# ── 관측 대상: A360-Assistant-Backend (실서비스 백엔드) ──
A360_BACKEND_URL=http://127.0.0.1:8000
# 인증 두 방식 (키가 있으면 키 우선, 없으면 관리자 로그인 폴백):
#  ① 서비스 API 키(권장, M2M) — Backend의 OPS_API_KEY와 같은 값. 사람 로그인 재사용 안 함.
A360_BACKEND_OPS_API_KEY=
#  ② 관리자 로그인(폴백) — Backend의 ADMIN_EMAILS 시드에 있는 계정(is_admin). 키 미설정 시 사용.
A360_BACKEND_ADMIN_EMAIL=
A360_BACKEND_ADMIN_PASSWORD=

# ── 관측 DB 직접 조회 (읽기 전용 롤) ──
# 관측 데이터 **조회**는 위 백엔드 API를 거치지 않고 관측 DB를 직접 읽는다.
# 백엔드를 거치면 관측이 관측 대상에 의존해, 백엔드가 죽었을 때 "왜 죽었는지" 보려던
# 과거 데이터까지 못 본다(APM 안티패턴). 쓰기(설정 변경)는 여전히 admin API를 쓴다.
#
# ⚠ 반드시 **SELECT 권한만 가진 롤**을 쓴다 — 백엔드의 OBSERVABILITY_DATABASE_URL과
#   같은 값(쓰기 가능)을 넣지 말 것.
# ⚠ 미설정이면 조회 API가 503을 낸다. 사본으로 조용히 폴백하지 않는다 — 구성 오류를
#   숨기면 "직접 읽는 줄 알았는데 실은 옛 사본을 보는" 상태를 아무도 모른다.
# SQLAlchemy 형식(postgresql+psycopg://)을 넣어도 동작하도록 정규화한다.
A360_OBSERVABILITY_DATABASE_URL=

# ── RAG 적재 서버(rag-server) 연동 ──
# 스케줄러(app/scheduler)와 프론트 'RAG 데이터 적재' 버튼이 트리거를 보낼 대상.
RAG_SERVER_URL=http://127.0.0.1:8200
# 스케줄러 주기(분)·옵션 — 실제 주기 실행은 다음 작업(현재 stub).
RAG_INGEST_INTERVAL_MINUTES=1440
RAG_INGEST_OPTION=1
# 스케줄 실행 엔진. local은 로컬 JSON 저장/dry-run 검증, eventbridge-ssm은 AWS EventBridge Scheduler -> SSM.
RAG_SCHEDULER_PROVIDER=local
AWS_REGION=ap-northeast-2
RAG_SCHEDULER_GROUP=default
RAG_SCHEDULER_ROLE_ARN=
RAG_SCHEDULER_SSM_DOCUMENT=AWS-RunShellScript
# EC2 내부에서 실행할 rag-server ingest URL. SSM RunCommand 기준이므로 localhost 권장.
RAG_INGEST_URL=http://127.0.0.1:8200/rag/ingest

# ── eval 실행기(executor)가 채점기를 돌릴 a360-eval-sandbox 위치 ──
# 기본은 backoffice 레포의 형제 폴더(예: Desktop\a360-eval-sandbox). 다른 위치면 지정.
A360_EVAL_SANDBOX=

# RAG ingest SQS integration path: EventBridge Scheduler -> SQS -> local/EC2 consumer -> localhost rag-server.
RAG_INGEST_SQS_QUEUE_URL=
RAG_INGEST_SQS_QUEUE_ARN=
