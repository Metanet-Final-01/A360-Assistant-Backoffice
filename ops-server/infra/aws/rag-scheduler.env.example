# AWS/EventBridge/SQS settings for RAG ingest scheduling.
# Non-secret values should come from CloudFormation Outputs or SSM Parameter Store.

AWS_REGION=ap-northeast-2
RAG_SCHEDULER_PROVIDER=eventbridge-sqs
RAG_SCHEDULER_GROUP=default

# Outputs from the nested CloudFormation stack.
RAG_INGEST_SQS_QUEUE_URL=
RAG_INGEST_SQS_QUEUE_ARN=
RAG_SCHEDULER_ROLE_ARN=

# Local-to-EC2 consumer target.
RAG_SERVER_URL=http://127.0.0.1:8200
RAG_INGEST_OPTION=3

# First integration test schedule. Switch to cron(...) after verification.
RAG_INGEST_SCHEDULE_EXPRESSION=rate(1 minute)
