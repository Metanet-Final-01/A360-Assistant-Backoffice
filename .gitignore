# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# 테스트/스모크 테스트 산출물 (일회성 검증용 — 리포에는 안 올림)
ops-server/backend/app/eval/**/test_output/
**/*.smoketest.json

# 환경변수
.env
.env.*
!.env.example

# ── rag-server ──
# RAG 수집 산출물 (크롤링 원본, 파싱된 스키마 등 — 로컬 아티팩트)
rag-server/data/
# RAG 적재 파이프라인 로그
rag-server/app/rag/logs/

# ── ops-server ──
# 로컬 데이터 (observability 로그·eval 로그/데이터셋, worfbench용 packages.json 복사본 등)
ops-server/backend/data/
# 카탈로그 산출물 (build_catalog.py로 재생성 가능)
ops-server/backend/app/eval/workflow/catalog_actions.json

# 로컬 전용 성능/실험 기록 — 리포에 올리지 않는 개인 참고 문서
docs/local/

# Goldset evaluation generated data/artifacts. Keep source scripts, READMEs, and
# curated rule files in git; regenerate bulky datasets, logs, reports, and
# reviewer export bundles locally.
scripts/goldset/dataset/
scripts/goldset/eval_inputs/
scripts/goldset/runner/logs/
scripts/goldset/evaluation/reports/
scripts/goldset/evaluation/exports/
scripts/goldset/evaluation/action_equivalence_candidates/
