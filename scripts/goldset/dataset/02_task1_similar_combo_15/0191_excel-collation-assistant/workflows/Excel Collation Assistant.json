                                "string": "from pandas import ExcelWriter\nimport pandas as pd\nimport glob\nimport os\n\ndef excel_consolidate(arg):\n    # output = r\"C:\\Users\\CLOUDSYS1\\Downloads\\Excel consolidate\\output\\Output.xlsx\"\n    output = arg['output']\n    writer = ExcelWriter(output)\n    print(str(writer))\n    extenstion = \"\\*.xlsx\"\n    # path = r\"C:\\Users\\CLOUDSYS1\\Downloads\\Excel consolidate\"\n    input = arg['input']\n    path = \"\"+str(input)+\"\"+str(extenstion)+\"\"\n    for filename in glob.glob(str(path)):\n        excel_file = pd.ExcelFile(filename)\n        print(\"file:\"+str(excel_file))\n        (_, f_name) = os.path.split(filename)\n        (f_short_name, _) = os.path.splitext(f_name)\n        for sheet_name in excel_file.sheet_names:\n            df_excel = pd.read_excel(filename, sheet_name=sheet_name)\n            df_excel.to_excel(writer, f_short_name+'_'+sheet_name, index=False)\n            \n    writer.save()\n    return \"Successfully Updated\"\n\n",
                                "type": "STRING"
                              }
