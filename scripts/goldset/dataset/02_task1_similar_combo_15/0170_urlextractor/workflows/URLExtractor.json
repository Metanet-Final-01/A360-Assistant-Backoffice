                "string": "import requests\nfrom bs4 import BeautifulSoup\n\n\n\ndef subURL(urls):\n\turl=urls\n\tURLS, FilePath = url.split(\", \")\n\tgrab = requests.get(URLS)\n\tsoup = BeautifulSoup(grab.text, 'html.parser')\n\n\tf = open(FilePath, \"w\")\n\n\tfor link in soup.find_all(\"a\"):\n\t\tdata = link.get('href')\n\t\tf.write(data)\n\t\tf.write(\"\\n\")\n\n\tf.close()",
