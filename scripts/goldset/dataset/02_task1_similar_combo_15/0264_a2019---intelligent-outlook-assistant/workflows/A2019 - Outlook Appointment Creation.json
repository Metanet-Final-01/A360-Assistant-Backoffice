        {
          "name": "script",
          "value": {
            "string": "import win32com.client\ndef appointment(dateapp):\n    oOutlook = win32com.client.Dispatch(\"Outlook.Application\")\n    appt = oOutlook.CreateItem(1) # 1 - olAppointmentItem\n    appt.Start = dateapp['app_date']\n    appt.Subject = dateapp['sub']\n    appt.Duration = dateapp['dur']\n    appt.Location = dateapp['loc']\n    appt.MeetingStatus = 1 # 1 - olMeeting; Changing the appointment to meeting\n    #only after changing the meeting status recipients can be added\n    appt.Recipients.Add(dateapp['send_email'])\n    appt.Save()\n    appt.Send()\n    appt.Save()\n\n\n",
            "type": "STRING"
          }
        },
        {
          "name": "version",
          "value": {
            "string": "3",
            "type": "STRING"
          }
