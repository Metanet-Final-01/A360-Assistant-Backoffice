                        },
                        {
                          "name": "scriptOption",
                          "value": {
                            "string": "SCRIPT",
                            "type": "STRING"
                          }
                        },
                        {
                          "name": "script",
                          "value": {
                            "string": "Set Arg = WScript.Arguments\n\nFunction TemplateToLetter(Arg)\n  \n  path = Arg(0)\n  \n  find_text = Split(Arg(1),\";\")\n  \n  replace_text = Split(Arg(2),\";\")\n  \n  PDFFileName = Arg(3)\n\nOn Error Resume Next\nSet objWord = CreateObject(\"Word.Application\")\nobjWord.Visible = False\n\nOn Error Resume Next\nSet objDoc = objWord.Documents.Open(path)\nSet objSelection = objWord.Selection\n\n  For i=0 to UBound(find_text)  \n  With objSelection.Find\n        .ClearFormatting\n        .Replacement.ClearFormatting\n        .MatchWholeWord = True\n        .Text = find_text(i)\n        .Execute ,,,,,,,,,replace_text(i),2\n    End With\n  Next\n\n  objDoc.ExportAsFixedFormat PDFFileName, 17\n  On Error Resume Next\n'Save the doc\n'objDoc.Save\nobjDoc.Close False\nobjWord.Quit\n    \n\nTemplateToLetter = \"Success\"\n  \nIf Err.Number <> 0 Then\n    TemplateToLetter = Err.Description\n    Err.Clear\nEnd If\n\nEnd Function",
                            "type": "STRING"
                          }
                        }
                      ],
                      "commandName": "vbscript.commands.openScript",
                      "disabled": false,
                      "packageName": "VBScript",
